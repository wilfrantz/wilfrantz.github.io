<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>SQL on DEDE</title><link>https://dede.dev/tags/sql/</link><description>Recent content in SQL on DEDE</description><generator>Hugo</generator><language>en-us</language><lastBuildDate>Fri, 09 Aug 2024 11:33:00 +0800</lastBuildDate><atom:link href="https://dede.dev/tags/sql/index.xml" rel="self" type="application/rss+xml"/><item><title>MySQL Cheat Sheet</title><link>https://dede.dev/posts/2024-08-09-sql-cheatsheet/</link><pubDate>Fri, 09 Aug 2024 11:33:00 +0800</pubDate><guid>https://dede.dev/posts/2024-08-09-sql-cheatsheet/</guid><description>&lt;p>&lt;code>MySQL&lt;/code> is one of the most popular relational database management systems (&lt;code>RDBMS&lt;/code>) in the world. Whether you’re just starting out or you’re a seasoned developer, this cheat sheet will help you navigate MySQL more efficiently. This guide covers a broad spectrum of MySQL commands, functions, and tips that are essential for day-to-day database management.&lt;/p>
&lt;h2 id="basic-mysql-commands">&lt;strong>Basic MySQL Commands&lt;/strong>&lt;/h2>
&lt;h3 id="create-a-database">Create a Database&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#e6edf3;background-color:#0d1117;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-sql" data-lang="sql">&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ff7b72">CREATE&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>&lt;span style="color:#ff7b72">DATABASE&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>db_name;&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="select-a-database">Select a Database&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#e6edf3;background-color:#0d1117;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-sql" data-lang="sql">&lt;span style="display:flex;">&lt;span>USE&lt;span style="color:#6e7681"> &lt;/span>db_name;&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="show-databases">Show Databases&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#e6edf3;background-color:#0d1117;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-sql" data-lang="sql">&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ff7b72">SHOW&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>DATABASES;&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="drop-a-database">Drop a Database&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#e6edf3;background-color:#0d1117;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-sql" data-lang="sql">&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ff7b72">DROP&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>&lt;span style="color:#ff7b72">DATABASE&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>db_name;&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="show-tables-in-a-database">Show Tables in a Database&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#e6edf3;background-color:#0d1117;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-sql" data-lang="sql">&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ff7b72">SHOW&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>TABLES;&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="describe-the-structure-of-a-table">Describe the Structure of a Table&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#e6edf3;background-color:#0d1117;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-sql" data-lang="sql">&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ff7b72">DESCRIBE&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>tableName;&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h2 id="table-operations">&lt;strong>Table Operations&lt;/strong>&lt;/h2>
&lt;h3 id="create-a-table">Create a Table&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#e6edf3;background-color:#0d1117;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-sql" data-lang="sql">&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ff7b72">CREATE&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>&lt;span style="color:#ff7b72">TABLE&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>tableName&lt;span style="color:#6e7681"> &lt;/span>(&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#6e7681"> &lt;/span>id&lt;span style="color:#6e7681"> &lt;/span>INT&lt;span style="color:#6e7681"> &lt;/span>&lt;span style="color:#ff7b72">PRIMARY&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>&lt;span style="color:#ff7b72">KEY&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>AUTO_INCREMENT,&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#6e7681"> &lt;/span>name&lt;span style="color:#6e7681"> &lt;/span>VARCHAR(&lt;span style="color:#a5d6ff">100&lt;/span>),&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#6e7681"> &lt;/span>age&lt;span style="color:#6e7681"> &lt;/span>INT,&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#6e7681"> &lt;/span>email&lt;span style="color:#6e7681"> &lt;/span>VARCHAR(&lt;span style="color:#a5d6ff">100&lt;/span>)&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#6e7681">&lt;/span>);&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="show-the-table-schema">Show the Table Schema&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#e6edf3;background-color:#0d1117;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-sql" data-lang="sql">&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ff7b72">SHOW&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>&lt;span style="color:#ff7b72">CREATE&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>&lt;span style="color:#ff7b72">TABLE&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>tableName;&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="drop-a-table">Drop a Table&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#e6edf3;background-color:#0d1117;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-sql" data-lang="sql">&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ff7b72">DROP&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>&lt;span style="color:#ff7b72">TABLE&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>tableName;&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="rename-a-table">Rename a Table&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#e6edf3;background-color:#0d1117;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-sql" data-lang="sql">&lt;span style="display:flex;">&lt;span>&lt;span style="color:#ff7b72">RENAME&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>&lt;span style="color:#ff7b72">TABLE&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>old_tableName&lt;span style="color:#6e7681"> &lt;/span>&lt;span style="color:#ff7b72">TO&lt;/span>&lt;span style="color:#6e7681"> &lt;/span>newTableName;&lt;span style="color:#6e7681">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="alter-a-table">Alter a Table&lt;/h3>
